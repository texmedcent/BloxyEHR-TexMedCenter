# Supabase - from project settings > API
# https://app.supabase.com/project/aabocgagjixwubtvflpw/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://aabocgagjixwubtvflpw.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-from-supabase-dashboard

# Public app URL (no trailing slash). Used for password-reset and signup confirmation links.
#
# Local dev: leave this line out — links will use http://localhost:3000 automatically.
#
# Vercel (Production + Preview): set NEXT_PUBLIC_SITE_URL in the Vercel project to your real
# HTTPS origin, e.g. https://your-app.vercel.app or https://yourdomain.com
# Never set production to http://localhost:3000 or reset emails will always point at localhost.
#
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
